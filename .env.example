# AI 运维助手 - 配置
# 复制此文件为 .env 并填入你的 API key

# --- 模型提供商配置 ---
# 支持的后端: openrouter | ollama | demo
LLM_BACKEND=demo

# OpenRouter 配置 (当 LLM_BACKEND=openrouter 时)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# Ollama 配置 (当 LLM_BACKEND=ollama 时)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- 应用配置 ---
APP_PORT=7860
DEBUG=true
